# ============================================================
# KronborgMarine Middleware — Miljøvariable
# Kopiér denne fil til .env.local og udfyld værdierne
# ============================================================

# --- Supabase ---
# Find disse i dit Supabase projekt under Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- WooCommerce ---
# Generer nøgler under: WooCommerce → Indstillinger → Avanceret → REST API
WOO_BASE_URL=https://kronborgmarinebaadudstyr.dk
WOO_CONSUMER_KEY=ck_...
WOO_CONSUMER_SECRET=cs_...
# Hemmeligt nøgleord til webhook-verifikation (vælg selv en lang, tilfældig streng)
WOO_WEBHOOK_SECRET=dit_hemmelige_webhook_noegleord

# --- admind POS (tilføjes når API docs foreligger) ---
ADMIND_API_URL=
ADMIND_API_KEY=

# --- App ---
# Bruges til webhook-URLs (ngrok URL til lokal udvikling, Vercel URL i produktion)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Dashboard adgangskode ---
# Ændres til noget stærkt i produktion
DASHBOARD_PASSWORD=KMB3000
